<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProtoInspector.JsonSampleEditWindow"
        Title="编辑 JSON 样例"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="420"
        Background="#F4F6F8">
  <Border Margin="12"
          Padding="10"
          Background="White"
          BorderBrush="#D9DEE5"
          BorderThickness="1"
          CornerRadius="6">
    <Grid RowDefinitions="Auto,*,Auto">
      <TextBlock Grid.Row="0"
                 Text="可以在下方修改生成的 JSON 样例，点击确定后会写入输入框。"
                 Foreground="#475569"
                 TextWrapping="Wrap"
                 Margin="0,0,0,8" />
      <TextBox x:Name="JsonTextBox"
               Grid.Row="1"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalContentAlignment="Top"
               FontFamily="Consolas"
               FontSize="13" />
      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Right"
                  Margin="0,10,0,0">
        <Button x:Name="CancelButton"
                Content="取消"
                Height="30"
                MinWidth="76"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center" />
        <Button x:Name="OkButton"
                Content="确定"
                Classes="accent"
                Height="30"
                MinWidth="76"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
